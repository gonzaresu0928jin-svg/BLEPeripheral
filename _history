n\n# ブロックの初期位置\nx = 2\ny = 0\n\n# ゲーム速度（ミリ秒）\nspeed = 500\n\ndef draw_field():\n\"\"\"フィールドと落下中ブロックを描画\"\"\"\ndisplay.clear()\nfor j in range(5):\n    for i in range(5):\n        if field[j][i] == 1:\n            display.set_pixel(i, j, 9)\ndisplay.set_pixel(x, y, 9)\n\ndef check_line_clear():\n\"\"\"最下段が埋まっていたら消去して上を落とす\"\"\"\nglobal field\nfor row in range(4, -1, -1):  # 下から上へ\nif all(field[row][i] == 1 for i in range(5)):\n            # この行を消去\nfor r in range(row, 0, -1):\n    field[r] = field[r - 1][:]\nfield[0] = [0] * 5\n\ndef can_move(nx, ny):\n\"\"\"移動可能か判定\"\"\"\nif nx < 0 or nx > 4 or ny > 4:\nreturn False\nif ny >= 0 and field[ny][nx] == 1:\nreturn False\nreturn True\n\nwhile True:\n    # 入力処理\nif button_a.is_pressed() and can_move(x - 1, y):\nx -= 1\nif button_b.is_pressed() and can_move(x + 1, y):\nx += 1\n\n    # 描画\ndraw_field()\nsleep(speed)\n\n    # 下に移動\nif can_move(x, y + 1):\n    y += 1\nelse:\n        # ブロックを固定\nfield[y][x] = 1\ncheck_line_clear()\n        # 新しいブロック生成\nx = random.randint(0, 4)\ny = 0\n        # ゲームオーバー判定\nif field[y][x] == 1:\n    display.scroll(\"GAME OVER\")\nbreak\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":279,"length1":35,"diffs":[[1,"    \"preferredEditor\": \"tsprj\"\n"]]}]}]},{"timestamp":1779240652254,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"pxt.json","patch":[{"start1":279,"length1":44,"diffs":[[1,""]]}]},{"type":"added","filename":"test.ts","value":"// テストはここに来ます。このパッケージが拡張機能として使用されるときにはコンパイルされません。\n"}]}],"snapshots":[{"timestamp":1779236319641,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>","main.ts":"\n","README.md":"","pxt.json":"{\n    \"name\": \"課題\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.bloc